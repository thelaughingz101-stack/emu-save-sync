{
  "emulators": [
    {
      "key": "pcsx2",
      "displayName": "PCSX2",
      "paths": {
        "windows": "%USERPROFILE%\\Documents\\PCSX2\\memcards",
        "linux": "~/.config/PCSX2/memcards",
        "mac": "~/Library/Application Support/PCSX2/memcards"
      },
      "saveStatePaths": {
        "windows": "%USERPROFILE%\\Documents\\PCSX2\\sstates",
        "linux": "~/.config/PCSX2/sstates",
        "mac": "~/Library/Application Support/PCSX2/sstates"
      },
      "processNames": [
        "pcsx2.exe",
        "pcsx2-qt.exe",
        "pcsx2-qtx64.exe",
        "pcsx2-qtx64-avx2.exe",
        "pcsx2x64.exe",
        "pcsx2x64-avx2.exe",
        "pcsx2",
        "pcsx2-qt",
        "PCSX2.AppImage"
      ]
    },
    {
      "key": "rpcs3",
      "displayName": "RPCS3",
      "paths": {
        "windows": "%USERPROFILE%\\RPCS3\\dev_hdd0\\home\\00000001\\savedata",
        "linux": "~/.config/rpcs3/dev_hdd0/home/00000001/savedata",
        "mac": "~/Library/Application Support/rpcs3/dev_hdd0/home/00000001/savedata"
      },
      "processNames": ["rpcs3.exe", "rpcs3", "rpcs3.AppImage"]
    }
  ]
}